# ====== LIFE OS — переменные окружения ======
# Скопируй этот файл в .env.local и впиши свои значения.
# .env.local НЕ попадает в git (он в .gitignore) — это безопасно.

# --- Supabase (Project → Settings → API) ---
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...           # публичный anon-ключ
SUPABASE_SERVICE_ROLE_KEY=eyJ...               # секретный service_role (только сервер!)

# --- AI ---
ANTHROPIC_API_KEY=sk-ant-...                   # анализ записей (Claude)
OPENAI_API_KEY=sk-...                          # транскрибация голоса (Whisper)

# --- Telegram ---
TELEGRAM_BOT_TOKEN=123456:ABC...               # токен от @BotFather
TELEGRAM_WEBHOOK_SECRET=придумай-длинную-строку # защита вебхука от чужих запросов

# --- Доступ к сайту (простой пароль на MVP) ---
APP_PASSWORD=придумай-пароль-для-входа
OWNER_USER_ID=                                  # оставь пустым — заполним позже

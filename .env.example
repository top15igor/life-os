# ====== LIFE OS — переменные окружения ======
# Скопируй этот файл в .env.local и впиши свои значения.
# .env.local НЕ попадает в git (он в .gitignore) — это безопасно.

# --- Supabase (Project → Settings → API) ---
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...           # публичный anon-ключ
SUPABASE_SERVICE_ROLE_KEY=eyJ...               # секретный service_role (только сервер!)

# --- AI ---
ANTHROPIC_API_KEY=sk-ant-...                   # анализ записей (Claude)
OPENAI_API_KEY=sk-...                          # транскрибация голоса (Whisper)

# --- Telegram ---
TELEGRAM_BOT_TOKEN=123456:ABC...               # токен от @BotFather
TELEGRAM_WEBHOOK_SECRET=придумай-длинную-строку # защита вебхука от чужих запросов

# --- Instagram (База знаний: распаковка постов/reels) ---
# Instagram блокирует «голые» запросы, поэтому контент достаём через сторонний
# scraper-API на RapidAPI. Без ключа бот попробует og-теги (срабатывает редко).
# 1) Заведи аккаунт на rapidapi.com → подпишись на любой Instagram Scraper API
#    (есть бесплатные лимиты). 2) Скопируй X-RapidAPI-Key сюда.
RAPIDAPI_KEY=                                   # ключ RapidAPI (включает надёжную распаковку)
# Хост/путь зависят от выбранного API. По умолчанию — instagram-scraper-api2 (GET).
# Плейсхолдеры: {url} → полная ссылка (url-encoded), {shortcode} → код поста.
RAPIDAPI_INSTAGRAM_HOST=instagram-scraper-api2.p.rapidapi.com
RAPIDAPI_INSTAGRAM_PATH=/v1/post_info?code_or_id_or_url={url}
# Если выбранный API работает через POST + form-data (эндпоинты *.php и т.п.) —
# задай тело запроса, тогда метод автоматически станет POST. Примеры:
#   RAPIDAPI_INSTAGRAM_PATH=/get_media_data.php
#   RAPIDAPI_INSTAGRAM_BODY=reel_post_code_or_url={url}
RAPIDAPI_INSTAGRAM_BODY=
RAPIDAPI_INSTAGRAM_METHOD=
# YouTube: субтитры берутся бесплатно; это запас на случай, если не вышло.
# Подпишись на любой YouTube-Transcript API на RapidAPI и впиши host/path.
# Плейсхолдеры {id} (id видео) и {url}. Тот же RAPIDAPI_KEY.
RAPIDAPI_YOUTUBE_HOST=
RAPIDAPI_YOUTUBE_PATH=/transcript?video_id={id}
RAPIDAPI_YOUTUBE_BODY=
RAPIDAPI_YOUTUBE_METHOD=

# --- Сохранение видео файлом (Instagram reels / TikTok) ---
# Сам файл видео скачивается на сервер и кладётся в bucket 'saved' (публичный).
# Instagram — через тот же RAPIDAPI_KEY выше; TikTok — бесплатный публичный сервис.
# Ограничение: файлы тяжелее 50 МБ не сохраняются. Нужна миграция supabase/saved_video.sql.
#
# YouTube: скачать файл с сервера НЕ выходит. YouTube отдаёт ссылки на googlevideo.com
# и блокирует их скачивание с IP датацентра (Vercel) — 403 (проверено на проде: и через
# InnerTube, и через RapidAPI-даунлоадеры). Поэтому YouTube сохраняется КАРТОЧКОЙ (обложка
# + разбор + кнопка «Открыть на YouTube»), без файла. Переменные ниже — «спящая» опция:
# они включат скачивание YouTube ТОЛЬКО с API, который сам проксирует файл со своего
# домена (не отдаёт голую googlevideo-ссылку). По умолчанию оставь их ПУСТЫМИ.
RAPIDAPI_YOUTUBE_DL_HOST=
RAPIDAPI_YOUTUBE_DL_PATH=
RAPIDAPI_YOUTUBE_DL_BODY=
RAPIDAPI_YOUTUBE_DL_METHOD=

# --- Доступ к сайту (простой пароль на MVP) ---
APP_PASSWORD=придумай-пароль-для-входа
OWNER_USER_ID=                                  # оставь пустым — заполним позже
